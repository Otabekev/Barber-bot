# Copy to .env and fill in real values

# From @BotFather on Telegram — MUST match the bot that opens the Mini App
BOT_TOKEN=your_telegram_bot_token_here

# Any long random string (min 32 chars) — signs JWTs
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_change_this_minimum_32_chars

# Shared secret between backend and bot — generate same way as SECRET_KEY
BOT_SECRET=your_bot_secret_here

# SQLite for local dev (default)
DATABASE_URL=sqlite+aiosqlite:///./barber.db
# Railway sets this automatically when you add PostgreSQL plugin:
# DATABASE_URL=postgresql://user:pass@host/dbname  ← handled automatically by config.py

# URL where your frontend is deployed (used in bot WebApp buttons)
MINI_APP_URL=https://your-frontend.up.railway.app

# NEVER true in production
DEV_MODE=false
